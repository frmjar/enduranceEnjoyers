---
import ArrowLeft from './ArrowLeft.astro'
import ArrowRight from './ArrowRight.astro'
import Calendar from './Calendar.astro'
import ChevronLeft from './ChevronLeft.astro'
import ChevronRight from './ChevronRight.astro'
import Close from './Close.astro'
import Expand from './Expand.astro'
import Menu from './Menu.astro'
import MultiPerson from './MultiPerson.astro'
import Play from './Play.astro'
import SinglePerson from './SinglePerson.astro'
import Trophy from './Trophy.astro'
import Twitch from './Twitch.astro'
import Twitter from './Twitter.astro'
import Youtube from './Youtube.astro'

export type IconTypes = 'arrowLeft' | 'arrowRight' | 'calendar' | 'chevronLeft' | 'chevronRight' | 'close' | 'expand' | 'menu' | 'multiPerson' | 'play' | 'singlePerson' | 'trophy' | 'twitch' | 'twitter' | 'youtube'

export interface Props {
  name: IconTypes
  class?: string
  size?: 'sm' | 'md' | 'lg' | 'xl'
  fill?: string
}

const {
  name,
  class: className = '',
  size = 'md',
  fill = 'currentColor',
  ...props
} = Astro.props

const iconComponents = {
  arrowLeft: ArrowLeft,
  arrowRight: ArrowRight,
  calendar: Calendar,
  chevronLeft: ChevronLeft,
  chevronRight: ChevronRight,
  close: Close,
  expand: Expand,
  menu: Menu,
  multiPerson: MultiPerson,
  play: Play,
  singlePerson: SinglePerson,
  trophy: Trophy,
  twitch: Twitch,
  twitter: Twitter,
  youtube: Youtube
}

const IconComponent = iconComponents[name]

if (!IconComponent) {
  console.warn(`Icono no encontrado: "${name}"`)
}
---

  {IconComponent && <IconComponent class={className} size={size} fill={fill} {...props} />}
