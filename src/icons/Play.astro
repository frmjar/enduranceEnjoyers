---
export interface Props {
  class?: string
  size?: 'sm' | 'md' | 'lg' | 'xl'
  fill?: string
}

const {
  class: className = '',
  size = 'md',
  fill = 'currentColor'
} = Astro.props

import { sizeClasses } from './sizes'
---

