---
export interface Props {
  class?: string
  size?: 'sm' | 'md' | 'lg' | 'xl'
}

const {
  class: className = '',
  size = 'md'
} = Astro.props

import { sizeClasses } from './sizes'
---

  <svg class={`${sizeClasses[size]} ${className}`} fill='none' viewBox='0 0 24 24' stroke='currentColor'>
    <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5l7 7-7 7' />
  </svg>
