---
import Icon from '../icons/Icon.astro'

const featuredRace = {
  Serie: 'Endurance Enjoyers Series',
  Season: '2024',
  Circuito: 'Circuit de Spa-Francorchamps',
  Coches: 'Porsche 911 GT3 Cup',
  Fecha: '15-16 de Junio, 2024',
  Duracion: '4 Horas',
  Lluvia: '30%',
  Team: 'SI',
  date: new Date('2024-06-15T14:00:00Z')
}
---

  <div class='space-y-8'>

        <!-- Evento Destacado -->
    <div class='relative overflow-hidden rounded-2xl bg-gradient-to-br from-racing-surface via-racing-elevated to-racing-surface border border-white/10'>
          <!-- Decoración de fondo -->
      <div class='absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-accent-orange/5 to-transparent pointer-events-none' />
      <div class='absolute bottom-0 left-0 w-32 h-32 bg-accent-orange/10 rounded-full blur-3xl pointer-events-none' />

          <!-- Badge "Próximo Evento" -->
      <div class='absolute top-4 left-4 md:top-6 md:left-6 z-10'>
        <span class='inline-flex items-center gap-2 px-3 py-1.5 bg-accent-orange text-white text-xs font-bold rounded-full uppercase tracking-wider shadow-lg shadow-accent-orange/30'>
          <span class='w-2 h-2 bg-white rounded-full animate-pulse' />
          Próximo Evento
        </span>
      </div>

      <div class='relative p-6 md:p-8 lg:p-10'>
        <div class='grid md:grid-cols-2 gap-8 items-center'>

              <!-- Info Principal -->
          <div class='space-y-6 pt-8 md:pt-0'>
            <div>
              <h3 class='text-3xl md:text-4xl font-bold text-text-primary mb-2'>
                {featuredRace.Serie}
              </h3>
              <p class='text-lg text-accent-orange font-medium'>
                {featuredRace.Circuito}
              </p>
            </div>

                <!-- Countdown -->
            <div class='countdown-container' data-race-date={featuredRace.date.toISOString()}>
              <div class='grid grid-cols-4 gap-3'>
                <div class='text-center p-3 bg-racing-black/50 rounded-xl border border-white/5'>
                  <span class='countdown-days text-2xl md:text-3xl font-bold text-text-primary block'>--</span>
                  <span class='text-xs text-text-muted uppercase tracking-wider'>Días</span>
                </div>
                <div class='text-center p-3 bg-racing-black/50 rounded-xl border border-white/5'>
                  <span class='countdown-hours text-2xl md:text-3xl font-bold text-text-primary block'>--</span>
                  <span class='text-xs text-text-muted uppercase tracking-wider'>Horas</span>
                </div>
                <div class='text-center p-3 bg-racing-black/50 rounded-xl border border-white/5'>
                  <span class='countdown-mins text-2xl md:text-3xl font-bold text-text-primary block'>--</span>
                  <span class='text-xs text-text-muted uppercase tracking-wider'>Mins</span>
                </div>
                <div class='text-center p-3 bg-racing-black/50 rounded-xl border border-white/5'>
                  <span class='countdown-secs text-2xl md:text-3xl font-bold text-accent-orange block'>--</span>
                  <span class='text-xs text-text-muted uppercase tracking-wider'>Segs</span>
                </div>
              </div>
            </div>

                <!-- Detalles rápidos -->
            <div class='flex flex-wrap gap-4'>
              <div class='flex items-center gap-2 text-text-secondary'>
                <Icon name='calendar' class='w-5 h-5 text-accent-orange' />
                <span>{featuredRace.Fecha}</span>
              </div>
              <div class='flex items-center gap-2 text-text-secondary'>
                <Icon name='flag' class='w-5 h-5 text-accent-orange' />
                <span>{featuredRace.Duracion}</span>
              </div>
              {featuredRace.Team === 'SI' && (
                <div class='flex items-center gap-2 text-text-secondary'>
                  <Icon name='trophy' class='w-5 h-5 text-accent-orange' />
                  <span>Evento de equipo</span>
                </div>
              )}
            </div>
          </div>

              <!-- Panel de Detalles -->
          <div class='bg-racing-black/40 backdrop-blur-sm rounded-xl p-6 border border-white/5'>
            <h4 class='text-sm font-semibold text-text-muted uppercase tracking-wider mb-4'>Detalles del evento</h4>
            <div class='space-y-4'>
              <div class='flex justify-between items-center py-2 border-b border-white/5'>
                <span class='text-text-secondary'>Serie</span>
                <span class='text-text-primary font-medium'>{featuredRace.Serie}</span>
              </div>
              <div class='flex justify-between items-center py-2 border-b border-white/5'>
                <span class='text-text-secondary'>Temporada</span>
                <span class='text-text-primary font-medium'>{featuredRace.Season}</span>
              </div>
              <div class='flex justify-between items-center py-2 border-b border-white/5'>
                <span class='text-text-secondary'>Circuito</span>
                <span class='text-text-primary font-medium text-right max-w-[60%]'>{featuredRace.Circuito}</span>
              </div>
              <div class='flex justify-between items-center py-2 border-b border-white/5'>
                <span class='text-text-secondary'>Coches</span>
                <span class='text-text-primary font-medium'>{featuredRace.Coches}</span>
              </div>
              <div class='flex justify-between items-center py-2'>
                <span class='text-text-secondary'>Prob. lluvia</span>
                <span class='text-text-primary font-medium'>{featuredRace.Lluvia || 'N/A'}</span>
              </div>
            </div>
          </div>
        </div>
      </div>

          <!-- Línea accent inferior -->
      <div class='h-1 bg-gradient-to-r from-transparent via-accent-orange to-transparent' />
    </div>
