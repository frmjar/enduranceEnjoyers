---
import SectionTitle from './SectionTitle.astro'
import Formulario from './contacto/Formulario.astro'
import Requisitos from './contacto/Requisitos.astro'
import Social from './contacto/Social.astro'

export interface Props {
  id?: string
  class?: string
}

const { id, class: className } = Astro.props;
---

  <section id={id} class={`spacing-section ${className || ''}`}>
    <div class='container mx-auto spacing-container'>
      <div class='max-w-6xl mx-auto'>

        <SectionTitle
          title='Únete al equipo'
          subtitle='¿Estás interesado en unirte a nosotros? ¡Nos encantaría saber de ti!'
        />

      <!-- Contenedor principal -->
        <div class='grid grid-cols-1 lg:grid-cols-3 gap-8'>
          <div class='space-y-6'>
            <Requisitos />
            <Social />
          </div>

          <div class='lg:col-span-2'>
            <Formulario />
          </div>
        </div>
      </div>
    </div>
  </section>
