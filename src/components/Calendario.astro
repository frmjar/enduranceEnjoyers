---
import Icon from '../icons/Icon.astro'
import CardCalendario from './CardCalendario.astro'
import SectionTitle from './SectionTitle.astro'
import { parseRaceDate, getWeekNumber, type RaceData, type RaceWithDate } from '../utils/date'
import { fetchRaces } from '../utils/api'

const scheduleData = await fetchRaces(Astro.url.origin)

const today = new Date()
const currentWeek = getWeekNumber(today)
const nextWeek = currentWeek + 1
const year = today.getFullYear()

const allRaces: RaceWithDate[] = scheduleData
  .map((r) => ({ ...r, date: parseRaceDate(r.Fecha), weekNum: 0 }))
  .map((r) => ({ ...r, weekNum: getWeekNumber(r.date) }))
  .filter((r) => r.date.getFullYear() === year && (r.weekNum === currentWeek || r.weekNum === nextWeek))
  .sort((a, b) => a.date.getTime() - b.date.getTime())

const thisWeekRaces = allRaces.filter(r => r.weekNum === currentWeek)
const nextWeekRaces = allRaces.filter(r => r.weekNum === nextWeek)

interface Section {
  title: string
  week: string
  iconClasses: string
  subtitleClasses: string
  races: RaceWithDate[]
}

const sections: Section[] = [
  {
    title: 'Esta semana',
    week: `Semana ${thisWeekRaces[0]?.Week || ''}`,
                    iconClasses: 'bg-accent-orange text-white',
                    subtitleClasses: 'text-accent-orange',
    races: thisWeekRaces
  },
  {
    title: 'Próxima semana',
    week: `Semana ${nextWeekRaces[0]?.Week || ''}`,
                    iconClasses: 'bg-racing-surface border border-border-subtle text-text-secondary',
    subtitleClasses: 'text-text-muted',
    races: nextWeekRaces
  }
]

const { class: className = '', ...props } = Astro.props;
---

  <section class={`spacing-section ${className}`} {...props}>
    <div class='max-w-8xl mx-auto px-4 sm:px-6 md:px-8 lg:px-12'>

      <SectionTitle title='Próximas carreras iRacing' subtitle='No te pierdas ningún evento de resistencia' />
      {allRaces.length > 0
        ? (
          <div class='space-y-12'>
            {sections.map(section => (
              section.races.length > 0 && (
                <div>
                    <div class='flex items-center gap-4 mb-6'>
                    <div class={`flex items-center justify-center w-12 h-12 rounded-lg ${section.iconClasses}`}>
                      <Icon name='calendar' class='w-6 h-6' />
                    </div>
                    <div>
                      <h3 class='text-xl md:text-2xl font-bold text-text-primary'>{section.title}</h3>
                      <span class={`text-sm ${section.subtitleClasses}`}>{section.week}</span>
                    </div>
                    <div class='flex-1 h-px bg-border-subtle' />
                  </div>

                  <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4'>
                    {section.races.map((race) => (
                      <CardCalendario race={race} />
                    ))}
                  </div>
                </div>
              )
            ))}
          </div>
          )
        : (
          <div class='text-center py-16 bg-racing-surface/50 rounded-lg border border-border-subtle'>
            <div class='w-20 h-20 bg-racing-elevated rounded-lg flex items-center justify-center mx-auto mb-6 border border-border-subtle'>
              <Icon name='calendar' size='lg' class='text-text-muted' />
            </div>
            <p class='text-text-muted text-lg'>
              No hay carreras programadas para esta semana o la siguiente
            </p>
          </div>
          )}
    <!-- Botón para ver calendario completo -->
      <div class='text-center mt-12'>
        <a
          href='/calendario'
          class='group inline-flex items-center gap-3 bg-accent-orange hover:bg-accent-orange-light text-racing-black font-bold px-8 py-4 rounded-lg transition-all duration-200 hover:-translate-y-0.5'
        >
          <Icon name='calendar' class='w-5 h-5' />
          <span>Ver calendario completo</span>
            <Icon name='arrowRight' class='transition-transform duration-300 group-hover:translate-x-1' />
        </a>
      </div>
    </div>
  </section>
