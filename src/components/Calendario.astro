---
import Icon from '../icons/Icon.astro'
import SectionTitle from './SectionTitle.astro'

const meses = {
  enero: 0,
  febrero: 1,
  marzo: 2,
  abril: 3,
  mayo: 4,
  junio: 5,
  julio: 6,
  agosto: 7,
  septiembre: 8,
  octubre: 9,
  noviembre: 10,
  diciembre: 11
}

const parseRaceDate = (fecha: string) => {
  const [d, m, y] = fecha.split(' ')
  const monthName = m.toLowerCase()
  return new Date(parseInt(y), meses[monthName], parseInt(d))
}

const getWeekNumber = (date: Date) => {
  const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()))
  d.setUTCDate(d.getUTCDate() + 4 - (d.getUTCDay() || 7))
  const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1))
  return Math.ceil(((d.getTime() - yearStart.getTime()) / 86400000 + 1) / 7)
}

let scheduleData = []
try {
  const res = await fetch(`${Astro.url.origin}/api/resistencias`)
  if (res.ok) scheduleData = await res.json()
  else console.error('Error al obtener datos:', res.status)
} catch (err) {
  console.error('Error de conexión con la API:', err)
}

const today = new Date()
const currentWeek = getWeekNumber(today)
const nextWeek = currentWeek + 1
const year = today.getFullYear()

// Filtrar carreras de esta semana y la próxima
const allRaces = scheduleData
  .map((r) => ({ ...r, date: parseRaceDate(r.Fecha), weekNum: 0 }))
  .map((r) => ({ ...r, weekNum: getWeekNumber(r.date) }))
  .filter((r) => r.date.getFullYear() === year && (r.weekNum === currentWeek || r.weekNum === nextWeek))
  .sort((a, b) => a.date.getTime() - b.date.getTime())

const thisWeekRaces = allRaces.filter(r => r.weekNum === currentWeek)
const nextWeekRaces = allRaces.filter(r => r.weekNum === nextWeek)

const { class: className = '', ...props } = Astro.props;
---

  <section class={`spacing-section ${className}`} {...props}>
    <div class='max-w-8xl mx-auto px-4 sm:px-6 md:px-8 lg:px-12'>
      <SectionTitle title='Próximas carreras iRacing' subtitle='No te pierdas ningún evento de resistencia' />

      {allRaces.length > 0
        ? (
          <div class='space-y-12'>

        <!-- Esta semana -->
            {thisWeekRaces.length > 0 && (
              <div>
                <div class='flex items-center gap-4 mb-6'>
                  <div class='flex items-center justify-center w-12 h-12 bg-gradient-to-br from-accent-orange to-accent-orange-light rounded-xl shadow-lg shadow-accent-orange/20'>
                    <Icon name='calendar' class='text-white w-6 h-6' />
                  </div>
                  <div>
                    <h3 class='text-xl md:text-2xl font-bold text-text-primary'>Esta semana</h3>
                    <span class='text-sm text-accent-orange'>Semana {currentWeek}</span>
                  </div>
                  <div class='flex-1 h-px bg-gradient-to-r from-accent-orange/50 via-border-light to-transparent' />
                </div>

                <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6'>
                  {thisWeekRaces.map((race, index) => {
                    const isFirst = index === 0

                    return (
                    <div class={`
                    relative bg-gradient-to-br from-racing-surface via-racing-elevated to-racing-surface
                    rounded-2xl overflow-hidden
                    border-2 ${isFirst ? 'border-accent-orange/50' : 'border-white/10 hover:border-accent-orange/30'}
                    transition-all duration-300 hover:shadow-2xl hover:shadow-accent-orange/10 hover:-translate-y-1
                    group
                  `}
                    >

                      <div class={`
                      relative h-28 flex items-end p-5
                      ${isFirst
                        ? 'bg-gradient-to-br from-accent-orange via-accent-orange-light to-accent-orange'
                        : 'bg-gradient-to-br from-racing-elevated via-racing-card to-racing-elevated'
                      }
                    `}
                >
                  <div class='absolute inset-0 opacity-10'>
                        <div class='absolute top-0 right-0 w-32 h-32 bg-white rounded-full -translate-y-1/2 translate-x-1/2' />
                        <div class='absolute bottom-0 left-0 w-24 h-24 bg-white rounded-full translate-y-1/2 -translate-x-1/2' />
                      </div>

                  {isFirst && (
                        <div class='absolute top-4 left-4'>
                          <span class='inline-flex items-center gap-1.5 px-3 py-1 bg-white/20 backdrop-blur-sm text-white text-xs font-bold rounded-full uppercase tracking-wider'>
                            <span class='w-2 h-2 bg-white rounded-full animate-pulse' />
                            Próximo
                          </span>
                        </div>
                      )}

                  <div class='absolute top-4 right-4'>
                        <span class={`text-4xl font-black opacity-30 ${isFirst ? 'text-white' : 'text-text-primary'}`}>
                          #{index + 1}
                        </span>
                      </div>

                  <div class={`relative z-10 ${isFirst ? 'text-white' : 'text-text-primary'}`}>
                        <span class='text-4xl font-black'>{race.Fecha.split(' ')[0]}</span>
                        <span class='text-lg font-medium ml-2 opacity-80'>{race.Fecha.split(' ')[1]}</span>
                      </div>
                </div>

                      <div class='p-6 space-y-5'>
                  <div>
                        <h3 class='text-xl font-bold text-text-primary mb-1 line-clamp-2'>{race.Serie}</h3>
                        <p class='text-accent-orange font-medium flex items-center gap-2'>
                          <Icon name='flag' class='w-4 h-4' />
                          <span class='line-clamp-1'>{race.Circuito}</span>
                        </p>
                      </div>

                  <div class='grid grid-cols-2 gap-3'>
                        <div class='bg-racing-black/30 rounded-xl p-3'>
                          <span class='text-xs text-text-muted uppercase tracking-wider block mb-1'>Duración</span>
                          <span class='text-text-primary font-semibold text-sm'>{race.Duracion}</span>
                        </div>
                        <div class='bg-racing-black/30 rounded-xl p-3'>
                          <span class='text-xs text-text-muted uppercase tracking-wider block mb-1'>Coches</span>
                          <span class='text-text-primary font-semibold text-sm'>{race.Coches}</span>
                        </div>
                        <div class='bg-racing-black/30 rounded-xl p-3'>
                          <span class='text-xs text-text-muted uppercase tracking-wider block mb-1'>Temporada</span>
                          <span class='text-text-primary font-semibold text-sm'>S{race.Season}</span>
                        </div>
                        <div class='bg-racing-black/30 rounded-xl p-3'>
                          <span class='text-xs text-text-muted uppercase tracking-wider block mb-1'>Lluvia</span>
                          <span class='text-text-primary font-semibold text-sm'>{race.Lluvia || 'N/A'}</span>
                        </div>
                      </div>

                  <div class='flex items-center justify-between pt-2 border-t border-white/5'>
                        {race.Team === 'SI'
                          ? (
                            <span class='inline-flex items-center gap-2 px-3 py-1.5 bg-accent-orange/20 text-accent-orange rounded-lg text-sm font-medium'>
                              <Icon name='trophy' class='w-4 h-4' />
                              Evento de equipo
                            </span>
                            )
                          : (
                            <span class='text-text-muted text-sm'>Evento individual</span>
                            )}
                        <span class='text-text-muted text-xs'>Semana {race.Week}</span>
                      </div>
                </div>

                      <div class={`h-1 ${isFirst ? 'bg-white/30' : 'bg-gradient-to-r from-transparent via-accent-orange/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity'}`} />
                    </div>
                    )
                  })}
                </div>
              </div>
            )}

        <!-- Próxima semana -->
            {nextWeekRaces.length > 0 && (
              <div>
                <div class='flex items-center gap-4 mb-6'>
                  <div class='flex items-center justify-center w-12 h-12 bg-racing-elevated rounded-xl border border-white/10'>
                    <Icon name='calendar' class='text-text-secondary w-6 h-6' />
                  </div>
                  <div>
                    <h3 class='text-xl md:text-2xl font-bold text-text-primary'>Próxima semana</h3>
                    <span class='text-sm text-text-muted'>Semana {nextWeek}</span>
                  </div>
                  <div class='flex-1 h-px bg-gradient-to-r from-white/20 via-border-light to-transparent' />
                </div>

                <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6'>
                  {nextWeekRaces.map((race, index) => (
                    <div class='relative bg-gradient-to-br from-racing-surface via-racing-elevated to-racing-surface rounded-2xl overflow-hidden border-2 border-white/10 hover:border-accent-orange/30 transition-all duration-300 hover:shadow-2xl hover:shadow-accent-orange/10 hover:-translate-y-1 group'>

                    <div class='relative h-28 flex items-end p-5 bg-gradient-to-br from-racing-elevated via-racing-card to-racing-elevated'>
                      <div class='absolute inset-0 opacity-10'>
                  <div class='absolute top-0 right-0 w-32 h-32 bg-white rounded-full -translate-y-1/2 translate-x-1/2' />
                  <div class='absolute bottom-0 left-0 w-24 h-24 bg-white rounded-full translate-y-1/2 -translate-x-1/2' />
                </div>

                      <div class='absolute top-4 right-4'>
                  <span class='text-4xl font-black opacity-30 text-text-primary'>#{index + 1}</span>
                </div>

                      <div class='relative z-10 text-text-primary'>
                  <span class='text-4xl font-black'>{race.Fecha.split(' ')[0]}</span>
                  <span class='text-lg font-medium ml-2 opacity-80'>{race.Fecha.split(' ')[1]}</span>
                </div>
                    </div>

                    <div class='p-6 space-y-5'>
                      <div>
                  <h3 class='text-xl font-bold text-text-primary mb-1 line-clamp-2'>{race.Serie}</h3>
                  <p class='text-accent-orange font-medium flex items-center gap-2'>
                        <Icon name='flag' class='w-4 h-4' />
                        <span class='line-clamp-1'>{race.Circuito}</span>
                      </p>
                </div>

                      <div class='grid grid-cols-2 gap-3'>
                  <div class='bg-racing-black/30 rounded-xl p-3'>
                        <span class='text-xs text-text-muted uppercase tracking-wider block mb-1'>Duración</span>
                        <span class='text-text-primary font-semibold text-sm'>{race.Duracion}</span>
                      </div>
                  <div class='bg-racing-black/30 rounded-xl p-3'>
                        <span class='text-xs text-text-muted uppercase tracking-wider block mb-1'>Coches</span>
                        <span class='text-text-primary font-semibold text-sm'>{race.Coches}</span>
                      </div>
                  <div class='bg-racing-black/30 rounded-xl p-3'>
                        <span class='text-xs text-text-muted uppercase tracking-wider block mb-1'>Temporada</span>
                        <span class='text-text-primary font-semibold text-sm'>S{race.Season}</span>
                      </div>
                  <div class='bg-racing-black/30 rounded-xl p-3'>
                        <span class='text-xs text-text-muted uppercase tracking-wider block mb-1'>Lluvia</span>
                        <span class='text-text-primary font-semibold text-sm'>{race.Lluvia || 'N/A'}</span>
                      </div>
                </div>

                      <div class='flex items-center justify-between pt-2 border-t border-white/5'>
                  {race.Team === 'SI'
                        ? (
                          <span class='inline-flex items-center gap-2 px-3 py-1.5 bg-accent-orange/20 text-accent-orange rounded-lg text-sm font-medium'>
                            <Icon name='trophy' class='w-4 h-4' />
                            Evento de equipo
                          </span>
                          )
                        : (
                          <span class='text-text-muted text-sm'>Evento individual</span>
                          )}
                  <span class='text-text-muted text-xs'>Semana {race.Week}</span>
                </div>
                    </div>

                    <div class='h-1 bg-gradient-to-r from-transparent via-accent-orange/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity' />
                  </div>
                  ))}
                </div>
              </div>
            )}
          </div>
          )
        : (
          <div class='text-center py-16 bg-racing-surface/50 rounded-2xl border border-white/5'>
            <div class='w-20 h-20 bg-racing-elevated rounded-2xl flex items-center justify-center mx-auto mb-6 border border-white/10'>
              <Icon name='calendar' size='lg' class='text-text-muted' />
            </div>
            <p class='text-text-muted text-lg'>
              No hay carreras programadas para esta semana o la siguiente
            </p>
          </div>
          )}

    <!-- Botón para ver calendario completo -->
      <div class='text-center mt-12'>
        <a
          href='/calendario'
          class='group inline-flex items-center gap-3 bg-gradient-to-r from-accent-orange to-accent-orange-light hover:from-accent-orange-light hover:to-accent-orange text-white font-bold px-8 py-4 rounded-xl transition-all duration-300 shadow-lg shadow-accent-orange/25 hover:shadow-xl hover:shadow-accent-orange/40 hover:-translate-y-0.5'
        >
          <Icon name='calendar' class='w-5 h-5' />
          <span>Ver calendario completo</span>
          <svg xmlns='http://www.w3.org/2000/svg' class='w-5 h-5 transition-transform duration-300 group-hover:translate-x-1' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M13 7l5 5m0 0l-5 5m5-5H6' />
          </svg>
        </a>
      </div>
    </div>
  </section>
