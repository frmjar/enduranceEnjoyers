---
import Icon from '../../icons/Icon.astro'

export interface Props {
  links: Array<{ href: string, label: string }>
}

const links = Astro.props.links;
---

<nav id='navbar' class='fixed top-0 left-0 w-full z-50 transition-all duration-300' role='navigation' aria-label='Navegación principal'>
  <div id='navbar-bg' class='absolute inset-0 bg-racing-black/0 backdrop-blur-none border-b border-transparent transition-all duration-300' />
  <div id='navbar-accent' class='absolute bottom-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-accent-cyan to-transparent opacity-0 transition-opacity duration-300' />

  <div class='relative flex items-center justify-center h-16 md:h-20 px-4 md:px-8 max-w-8xl mx-auto'>
    <div id='scroll-logo' class='absolute left-4 md:left-16 flex-shrink-0 opacity-0 -translate-x-4 transition-all duration-300'>
      <a href='/' class='block group' aria-label='Endurance Enjoyers - Inicio'>
        <img
          src='/logotextclear.webp'
          alt=''
          aria-hidden='true'
          class='h-10 md:h-14 w-auto transition-transform duration-300 group-hover:scale-105'
          width='200'
          height='56'
        />
      </a>
    </div>

    <div id='desktop-nav' class='hidden md:flex items-center gap-1 transition-all duration-300 ease-out'>
      {links.map((link, i) => (
        <a
          href={link.href}
          class='nav-link relative px-4 py-2 text-sm font-semibold uppercase tracking-wider text-white/70 hover:text-accent-cyan transition-all duration-200 group'
        >
          <span class='relative z-10'>{link.label}</span>
          <span class='absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-accent-cyan rounded-full transition-all duration-300 group-hover:w-3/4' />
        </a>
      ))}
    </div>

    <button
      id='mobile-menu-button'
      class='absolute right-4 md:right-8 md:hidden z-20 p-2 text-white/80 hover:text-white transition-colors'
      aria-label='Abrir menú'
      aria-controls='mobile-menu'
      aria-expanded='false'
    >
      <Icon name='menu' />
    </button>
  </div>
</nav>

<script>
  const navbardir = document.getElementById('navbardir')
  const logo = document.getElementById('scroll-logo')
  const navbarBg = document.getElementById('navbar-bg')
  const navbarAccent = document.getElementById('navbar-accent')
  const desktopNav = document.getElementById('desktop-nav')
  const mobileBtn = document.getElementById('mobile-menu-button')

  const updateNavbar = () => {
    if (!navbardir) return
    const rect = navbardir.getBoundingClientRect()
    const altura = rect.height

    if (window.scrollY > altura / 3) {
      logo?.classList.add('opacity-100', 'translate-x-0')
      logo?.classList.remove('opacity-0', '-translate-x-4')
      navbarBg?.classList.add('bg-racing-black/95', 'backdrop-blur-md', 'border-border-subtle')
      navbarBg?.classList.remove('bg-racing-black/0', 'backdrop-blur-none', 'border-transparent')
      navbarAccent?.classList.add('opacity-60')
      navbarAccent?.classList.remove('opacity-0')
      desktopNav?.classList.add('md:ml-32')
    } else {
      logo?.classList.remove('opacity-100', 'translate-x-0')
      logo?.classList.add('opacity-0', '-translate-x-4')
      navbarBg?.classList.remove('bg-racing-black/95', 'backdrop-blur-md', 'border-border-subtle')
      navbarBg?.classList.add('bg-racing-black/0', 'backdrop-blur-none', 'border-transparent')
      navbarAccent?.classList.remove('opacity-60')
      navbarAccent?.classList.add('opacity-0')
      desktopNav?.classList.remove('md:ml-32')
    }
  }

  document.addEventListener('DOMContentLoaded', updateNavbar)
  window.addEventListener('scroll', updateNavbar, { passive: true })

  mobileBtn?.addEventListener('click', () => {
    window.openMobileMenu?.()
  })
</script>
