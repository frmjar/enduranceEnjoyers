---
import Icon from '../../icons/Icon.astro'

---
  <div class='relative overflow-hidden bg-racing-card rounded-lg border border-accent-orange/15 p-6 group hover:border-accent-orange/30 transition-all'>
    <div class='absolute top-0 right-0 w-20 h-20 bg-accent-orange/5 rounded-full -mr-10 -mt-10 group-hover:scale-150 transition-transform duration-300' />

    <div class='relative space-y-4'>
      <div class='w-12 h-12 bg-accent-orange/15 rounded-lg flex items-center justify-center'>
        <Icon name='singlePerson' class='w-6 h-6 text-accent-orange' />
      </div>

      <h3 class='text-lg font-bold text-text-primary'>Requisitos</h3>

      <ul class='space-y-2.5'>
        <li class='flex items-start gap-2.5 text-sm text-text-secondary'>
          <div class='w-1.5 h-1.5 bg-accent-orange rounded-full mt-1.5 flex-shrink-0' />
          <span>Cuenta iRacing activa</span>
        </li>
        <li class='flex items-start gap-2.5 text-sm text-text-secondary'>
          <div class='w-1.5 h-1.5 bg-accent-orange rounded-full mt-1.5 flex-shrink-0' />
          <span>Usuario activo en Discord</span>
        </li>
        <li class='flex items-start gap-2.5 text-sm text-text-secondary'>
          <div class='w-1.5 h-1.5 bg-accent-orange rounded-full mt-1.5 flex-shrink-0' />
          <span>Pasión por las carreras</span>
        </li>
      </ul>
    </div>
  </div>
