---
import Icon from '../../icons/Icon.astro'

---
  <div class='relative overflow-hidden bg-racing-card rounded-lg border border-accent-cyan/15 p-6 group hover:border-accent-cyan/30 transition-all'>
    <div class='absolute top-0 right-0 w-20 h-20 bg-accent-cyan/5 rounded-full -mr-10 -mt-10 group-hover:scale-150 transition-transform duration-300' />

    <div class='relative space-y-4'>
      <div class='w-12 h-12 bg-accent-cyan/15 rounded-lg flex items-center justify-center'>
        <Icon name='twitter' class='w-6 h-6 text-accent-cyan' />
      </div>

      <h3 class='text-lg font-bold text-text-primary'>Conecta</h3>

      <a
        href='https://x.com/EnduEnjoyers'
        target='_blank'
        rel='noreferrer'
        class='flex items-center justify-between p-3 rounded-md bg-racing-elevated border border-border-subtle hover:bg-accent-cyan/10 hover:border-accent-cyan/30 transition-all group/link'
      >
        <div class='flex items-center gap-2'>
          <div class='w-8 h-8 rounded-md bg-accent-cyan/15 flex items-center justify-center'>
            <Icon name='twitter' class='w-4 h-4 text-accent-cyan' />
          </div>
          <span class='text-sm font-medium text-text-primary'>@EnduEnjoyers</span>
        </div>
        <Icon name='twitter' class='w-4 h-4 text-text-muted group-hover/link:text-accent-cyan transition-colors' />
      </a>
    </div>
  </div>
