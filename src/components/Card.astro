---
import Icon from '../icons/Icon.astro'

const {
  title,
  description,
  date,
  icon,
  iconColor = 'bg-accent-orange',
  results = [],
  details = [],
  class: className = '',
  titleInline = false,
  titleHoverColor = false,
  headerDate = null,
  headerSeason = null
} = Astro.props
---

  <div class={`
  relative overflow-hidden
  bg-racing-card
  rounded-lg
  border border-border-subtle hover:border-accent-cyan/40
  transition-all duration-200
  hover:-translate-y-1
  group p-6
  ${className}
`}
  >

    {(headerDate || headerSeason) && (
      <header class='relative flex items-center justify-between mb-4'>
        {headerDate && (
          <time class='text-sm font-semibold text-accent-orange bg-accent-orange/10 px-3 py-1.5 rounded-md border border-accent-orange/20'>
            {headerDate}
          </time>
        )}
        {headerSeason && (
          <span class='text-sm text-text-muted bg-racing-surface px-3 py-1.5 rounded-md'>
            {headerSeason}
          </span>
        )}
      </header>
    )}

    {(icon || date || (title && titleInline)) && !headerDate && !headerSeason && (
      <div class='relative flex items-center justify-between mb-6'>
        {titleInline
          ? (
            <div class='flex items-center'>
              {icon && (
                <div class={`w-12 h-12 ${iconColor} rounded-lg flex items-center justify-center mr-4`}>
                  <Icon name={icon} class='text-white' />
                </div>
              )}
              {title && (
                <h3 class='text-xl font-semibold text-white leading-tight'>
                  {title}
                </h3>
              )}
            </div>
            )
          : (
              icon && (
                <div class={`w-12 h-12 ${iconColor} rounded-lg flex items-center justify-center`}>
                  <Icon name={icon} class='text-white' />
                </div>
              )
            )}

        {date && (
          <span class='text-sm font-medium text-text-secondary bg-racing-surface px-3 py-1.5 rounded-md'>
            {date}
          </span>
        )}
      </div>
    )}

    {title && !titleInline && (
      <h3 class={`relative text-xl font-bold mb-4 text-text-primary leading-tight ${titleHoverColor ? 'group-hover:text-accent-cyan transition-colors duration-200' : ''}`}>
        {title}
      </h3>
    )}

    {description && (
      <p class='relative text-text-secondary leading-relaxed mb-6'>
        {description}
      </p>
    )}

    <div class='relative'>
      <slot />
    </div>

    {details.length > 0 && (
      <div class='relative space-y-3'>
        {details.map((detail, detailIndex) => (
          <div class='flex items-center gap-2'>
            <div class='w-2 h-2 bg-accent-cyan rounded-full' />
            <span class='text-sm font-medium text-accent-cyan'>{detail.label}:</span>
            <span class='text-sm text-text-secondary'>{detail.value}</span>
          </div>
        ))}
      </div>
    )}

    {results.length > 0 && (
      <div class='relative space-y-3 mt-6'>
        {results.map((result, resultIndex) => (
          <div class='flex items-center space-x-3'>
            <div class='w-2 h-2 bg-accent-cyan rounded-full flex-shrink-0' />
            <span class='text-text-primary text-sm'>{result}</span>
          </div>
        ))}
      </div>
    )}
  </div>
