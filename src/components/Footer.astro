---
import { Image } from 'astro:assets'
import Logo from '../../public/logo.webp'

import SocialLinks from './SocialLinks.astro'

const brandName = 'Endurance Enjoyers'
const currentYear = new Date().getFullYear()

const siteLinks = [
  { name: 'Inicio', url: '/' },
  { name: 'Calendario', url: '/#calendario' },
  { name: 'Novedades', url: '/#novedades' },
  { name: 'Galería', url: '/#galeria' },
  { name: 'Contacto', url: '/#contacto' }
]

const { class: className = '', ...props } = Astro.props;
---

<footer class={`relative py-10 md:py-14 px-4 bg-racing-dark ${className}`} role='contentinfo' {...props}>
  <div class='absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent-cyan/40 to-transparent' />

  <div class='max-w-6xl mx-auto'>
    <div class='grid grid-cols-1 md:grid-cols-3 gap-10 mb-10'>
      <div class='text-center md:text-left'>
        <a href='/' class='inline-block group' aria-label={brandName}>
          <Image
            src={Logo}
            width={90}
            height={90}
            alt=''
            aria-hidden='true'
            class='mx-auto md:mx-0 mb-4 opacity-80 group-hover:opacity-100 transition-opacity duration-300'
          />
        </a>
        <p class='text-sm text-secondary leading-relaxed max-w-xs mx-auto md:mx-0'>
          Equipo de carreras de resistencia en iRacing. Pasión por el simracing, compañerismo y respeto en pista.
        </p>
      </div>

      <div>
        <h3 class='font-heading text-text-primary font-bold text-lg mb-5 text-center md:text-left uppercase tracking-wider'>Enlaces</h3>
        <ul class='space-y-3 text-center md:text-left'>
          {siteLinks.map(link => (
            <li>
              <a
                href={link.url}
                class='text-secondary hover:text-accent-cyan transition-colors inline-flex items-center gap-2 group'
              >
                <span class='w-0 h-0.5 bg-accent-cyan rounded-full transition-all duration-200 group-hover:w-3' />
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class='text-center md:text-left'>
        <h3 class='font-heading text-text-primary font-bold text-lg mb-5 uppercase tracking-wider'>Síguenos</h3>
        <div class='flex justify-center md:justify-start gap-3 mb-5'>
          <SocialLinks variant='footer' />
        </div>
        <p class='text-sm text-secondary'>
          ¿Preguntas? <a href='/#contacto' class='text-text-primary hover:text-accent-cyan transition-colors'>Contáctanos</a>
        </p>
      </div>
    </div>

    <div class='h-px bg-gradient-to-r from-transparent via-border-default to-transparent my-8' />

    <div class='flex flex-col md:flex-row justify-between items-center gap-4'>
      <p class='text-sm text-muted'>&copy; {currentYear} {brandName}. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
