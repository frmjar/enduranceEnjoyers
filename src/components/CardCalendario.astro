---
import Icon from '../icons/Icon.astro'

const { race } = Astro.props
---

  <div class='relative bg-racing-card rounded-lg overflow-hidden border border-border-subtle hover:border-accent-cyan/40 transition-all duration-200 group w-full flex flex-col min-h-96'>

    <div class='relative h-14 flex items-end p-3 bg-racing-surface flex-shrink-0 border-b border-border-subtle'>

      <div class='absolute top-2 right-3'>
        <span class='text-xs font-bold text-text-muted'>S{race.Season}</span>
      </div>

      <div class='relative z-10 text-text-primary'>
        <span class='text-3xl font-black'>{race.Fecha.split(' ')[0]}</span>
        <span class='text-base font-medium ml-2 opacity-80'>{race.Fecha.split(' ')[1]}</span>
      </div>
    </div>

    <div class='p-4 flex-grow flex flex-col'>
      <div class='space-y-3 flex-grow'>
        <div>
          <h3 class='text-lg font-bold text-text-primary mb-1 line-clamp-2'>{race.Serie}</h3>
          <p class='text-sm text-accent-cyan font-medium flex items-center gap-2'>
            <span class='line-clamp-1'>{race.Circuito}</span>
          </p>
        </div>

        <div class='grid grid-cols-2 gap-2'>
          <div class='col-span-2 bg-racing-black/50 rounded-md p-2'>
            <span class='text-xs text-text-muted uppercase tracking-wider block mb-0.5'>Coches</span>
            <span class='text-text-primary font-semibold text-sm'>{race.Coches}</span>
          </div>
          <div class='bg-racing-black/50 rounded-md p-2'>
            <span class='text-xs text-text-muted uppercase tracking-wider block mb-0.5'>Duración</span>
            <span class='text-text-primary font-semibold text-sm'>{race.Duracion}</span>
          </div>
          <div class='bg-racing-black/50 rounded-md p-2'>
            <span class='text-xs text-text-muted uppercase tracking-wider block mb-0.5'>Lluvia</span>
            <span class='text-text-primary font-semibold text-sm'>{race.Lluvia || 'N/A'}</span>
          </div>
        </div>
      </div>

      <div class='flex items-center justify-between pt-3 mt-3 border-t border-border-subtle'>
        {race.Team === 'SI'
          ? (
            <span class='inline-flex items-center gap-1.5 px-2 py-1 bg-accent-orange/10 text-accent-orange rounded-md text-xs font-medium'>
              <Icon name='multiPerson' class='w-3.5 h-3.5' />
              Evento de equipo
            </span>
            )
          : (
            <span class='inline-flex items-center gap-1.5 px-2 py-1 bg-accent-cyan/10 text-accent-cyan rounded-md text-xs font-medium'>
              <Icon name='singlePerson' class='w-3.5 h-3.5' />
              Evento individual
            </span>
            )}
        <span class='text-text-muted text-sm font-bold'>Semana {race.Week}</span>
      </div>
    </div>
  </div>
