---
interface Link {
  href: string
  label: string
}

interface Props {
  links: Link[]
}

const { links } = Astro.props as Props
---

<div class='hidden md:flex items-center gap-1'>
  {links.map((link: Link) => (
    <a 
      href={link.href} 
      class='nav-link relative px-4 py-2 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200 group'
    >
      <span class='relative z-10'>{link.label}</span>
      <!-- Línea accent inferior en hover -->
      <span class='absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-accent-orange rounded-full transition-all duration-300 group-hover:w-3/4'></span>
      <!-- Fondo sutil en hover -->
      <span class='absolute inset-0 rounded-lg bg-white/0 group-hover:bg-white/5 transition-colors duration-200'></span>
    </a>
  ))}
</div>
