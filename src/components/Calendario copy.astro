---
import Icon from '../icons/Icon.astro'
import SectionTitle from './SectionTitle.astro'

const meses = {
  enero: 0,
  febrero: 1,
  marzo: 2,
  abril: 3,
  mayo: 4,
  junio: 5,
  julio: 6,
  agosto: 7,
  septiembre: 8,
  octubre: 9,
  noviembre: 10,
  diciembre: 11
}

const diasSemana = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado']

const parseRaceDate = (fecha: string) => {
  const [d, m, y] = fecha.split(' ')
  const monthName = m.toLowerCase()
  return new Date(parseInt(y), meses[monthName], parseInt(d))
}

let scheduleData = []
try {
  const res = await fetch(`${Astro.url.origin}/api/resistencias`)
  if (res.ok) scheduleData = await res.json()
  else console.error('Error al obtener datos:', res.status)
} catch (err) {
  console.error('Error de conexión con la API:', err)
}

const today = new Date()
const year = today.getFullYear()

// Obtener todas las carreras futuras ordenadas
const upcomingRaces = scheduleData
  .map((r) => ({ ...r, date: parseRaceDate(r.Fecha) }))
  .filter((r) => r.date >= today)
  .sort((a, b) => a.date.getTime() - b.date.getTime())

// Separar evento destacado y resto
const featuredRace = upcomingRaces[0] || null
const otherRaces = upcomingRaces.slice(1, 5) // Mostrar hasta 4 más

const { class: className = '', ...props } = Astro.props;
---

  <section class={`spacing-section ${className}`} {...props}>
    <div class='max-w-8xl mx-auto px-4 sm:px-6 md:px-8 lg:px-12'>
      <SectionTitle title='Próximas carreras iRacing' subtitle='No te pierdas ningún evento de resistencia' />

      {featuredRace
        ? (
          <div class='space-y-8'>

        <!-- Evento Destacado -->
            <div class='relative overflow-hidden rounded-2xl bg-gradient-to-br from-racing-surface via-racing-elevated to-racing-surface border border-white/10'>
          <!-- Decoración de fondo -->
              <div class='absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-accent-orange/5 to-transparent pointer-events-none' />
              <div class='absolute bottom-0 left-0 w-32 h-32 bg-accent-orange/10 rounded-full blur-3xl pointer-events-none' />

          <!-- Badge "Próximo Evento" -->
              <div class='absolute top-4 left-4 md:top-6 md:left-6 z-10'>
                <span class='inline-flex items-center gap-2 px-3 py-1.5 bg-accent-orange text-white text-xs font-bold rounded-full uppercase tracking-wider shadow-lg shadow-accent-orange/30'>
                  <span class='w-2 h-2 bg-white rounded-full animate-pulse' />
                  Próximo Evento
                </span>
              </div>

              <div class='relative p-6 md:p-8 lg:p-10'>
                <div class='grid md:grid-cols-2 gap-8 items-center'>

              <!-- Info Principal -->
                  <div class='space-y-6 pt-8 md:pt-0'>
                    <div>
                      <h3 class='text-3xl md:text-4xl font-bold text-text-primary mb-2'>
                        {featuredRace.Serie}
                      </h3>
                      <p class='text-lg text-accent-orange font-medium'>
                        {featuredRace.Circuito}
                      </p>
                    </div>

                <!-- Countdown -->
                    <div class='countdown-container' data-race-date={featuredRace.date.toISOString()}>
                      <div class='grid grid-cols-4 gap-3'>
                        <div class='text-center p-3 bg-racing-black/50 rounded-xl border border-white/5'>
                          <span class='countdown-days text-2xl md:text-3xl font-bold text-text-primary block'>--</span>
                          <span class='text-xs text-text-muted uppercase tracking-wider'>Días</span>
                        </div>
                        <div class='text-center p-3 bg-racing-black/50 rounded-xl border border-white/5'>
                          <span class='countdown-hours text-2xl md:text-3xl font-bold text-text-primary block'>--</span>
                          <span class='text-xs text-text-muted uppercase tracking-wider'>Horas</span>
                        </div>
                        <div class='text-center p-3 bg-racing-black/50 rounded-xl border border-white/5'>
                          <span class='countdown-mins text-2xl md:text-3xl font-bold text-text-primary block'>--</span>
                          <span class='text-xs text-text-muted uppercase tracking-wider'>Mins</span>
                        </div>
                        <div class='text-center p-3 bg-racing-black/50 rounded-xl border border-white/5'>
                          <span class='countdown-secs text-2xl md:text-3xl font-bold text-accent-orange block'>--</span>
                          <span class='text-xs text-text-muted uppercase tracking-wider'>Segs</span>
                        </div>
                      </div>
                    </div>

                <!-- Detalles rápidos -->
                    <div class='flex flex-wrap gap-4'>
                      <div class='flex items-center gap-2 text-text-secondary'>
                        <Icon name='calendar' class='w-5 h-5 text-accent-orange' />
                        <span>{featuredRace.Fecha}</span>
                      </div>
                      <div class='flex items-center gap-2 text-text-secondary'>
                        <Icon name='flag' class='w-5 h-5 text-accent-orange' />
                        <span>{featuredRace.Duracion}</span>
                      </div>
                      {featuredRace.Team === 'SI' && (
                        <div class='flex items-center gap-2 text-text-secondary'>
                          <Icon name='trophy' class='w-5 h-5 text-accent-orange' />
                          <span>Evento de equipo</span>
                        </div>
                      )}
                    </div>
                  </div>

              <!-- Panel de Detalles -->
                  <div class='bg-racing-black/40 backdrop-blur-sm rounded-xl p-6 border border-white/5'>
                    <h4 class='text-sm font-semibold text-text-muted uppercase tracking-wider mb-4'>Detalles del evento</h4>
                    <div class='space-y-4'>
                      <div class='flex justify-between items-center py-2 border-b border-white/5'>
                        <span class='text-text-secondary'>Serie</span>
                        <span class='text-text-primary font-medium'>{featuredRace.Serie}</span>
                      </div>
                      <div class='flex justify-between items-center py-2 border-b border-white/5'>
                        <span class='text-text-secondary'>Temporada</span>
                        <span class='text-text-primary font-medium'>{featuredRace.Season}</span>
                      </div>
                      <div class='flex justify-between items-center py-2 border-b border-white/5'>
                        <span class='text-text-secondary'>Circuito</span>
                        <span class='text-text-primary font-medium text-right max-w-[60%]'>{featuredRace.Circuito}</span>
                      </div>
                      <div class='flex justify-between items-center py-2 border-b border-white/5'>
                        <span class='text-text-secondary'>Coches</span>
                        <span class='text-text-primary font-medium'>{featuredRace.Coches}</span>
                      </div>
                      <div class='flex justify-between items-center py-2'>
                        <span class='text-text-secondary'>Prob. lluvia</span>
                        <span class='text-text-primary font-medium'>{featuredRace.Lluvia || 'N/A'}</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

          <!-- Línea accent inferior -->
              <div class='h-1 bg-gradient-to-r from-transparent via-accent-orange to-transparent' />
            </div>

        <!-- Grid de próximos eventos -->
            {otherRaces.length > 0 && (
              <div>
                <h3 class='text-xl font-bold text-text-primary mb-6 flex items-center gap-3'>
                  <span class='w-8 h-0.5 bg-accent-orange rounded-full' />
                  Más eventos próximos
                </h3>

                <div class='grid sm:grid-cols-2 lg:grid-cols-4 gap-4'>
                  {otherRaces.map((race) => (
                    <div class='group relative bg-racing-surface hover:bg-racing-elevated rounded-xl p-5 border border-white/5 hover:border-accent-orange/30 transition-all duration-300 hover:-translate-y-1'>
                  <!-- Fecha destacada -->
                      <div class='flex items-start justify-between mb-4'>
                        <div class='flex flex-col'>
                          <span class='text-2xl font-bold text-text-primary'>{race.Fecha.split(' ')[0]}</span>
                          <span class='text-sm text-text-muted'>{race.Fecha.split(' ')[1]}</span>
                        </div>
                        <span class='px-2 py-1 bg-racing-black/50 rounded-lg text-xs text-text-muted'>
                          S{race.Season}
                        </span>
                      </div>

                  <!-- Info -->
                      <h4 class='font-semibold text-text-primary mb-1 line-clamp-1'>{race.Serie}</h4>
                      <p class='text-sm text-text-secondary line-clamp-1 mb-3'>{race.Circuito}</p>

                  <!-- Tags -->
                      <div class='flex flex-wrap gap-2'>
                        <span class='text-xs px-2 py-1 bg-racing-black/50 rounded text-text-muted'>{race.Duracion}</span>
                        {race.Team === 'SI' && (
                          <span class='text-xs px-2 py-1 bg-accent-orange/20 text-accent-orange rounded'>Equipo</span>
                        )}
                      </div>

                  <!-- Hover accent -->
                      <div class='absolute bottom-0 left-0 right-0 h-0.5 bg-accent-orange scale-x-0 group-hover:scale-x-100 transition-transform duration-300 rounded-b-xl' />
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
          )
        : (
          <div class='text-center py-16 bg-racing-surface/50 rounded-2xl border border-white/5'>
            <div class='w-20 h-20 bg-racing-elevated rounded-2xl flex items-center justify-center mx-auto mb-6 border border-white/10'>
              <Icon name='calendar' size='lg' class='text-text-muted' />
            </div>
            <p class='text-text-muted text-lg'>
              No hay carreras programadas próximamente
            </p>
          </div>
          )}

    <!-- Botón para ver calendario completo -->
      <div class='text-center mt-12'>
        <a
          href='/calendario'
          class='group inline-flex items-center gap-3 bg-gradient-to-r from-accent-orange to-accent-orange-light hover:from-accent-orange-light hover:to-accent-orange text-white font-bold px-8 py-4 rounded-xl transition-all duration-300 shadow-lg shadow-accent-orange/25 hover:shadow-xl hover:shadow-accent-orange/40 hover:-translate-y-0.5'
        >
          <Icon name='calendar' class='w-5 h-5' />
          <span>Ver calendario completo</span>
          <svg xmlns='http://www.w3.org/2000/svg' class='w-5 h-5 transition-transform duration-300 group-hover:translate-x-1' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M13 7l5 5m0 0l-5 5m5-5H6' />
          </svg>
        </a>
      </div>
    </div>
  </section>

    <script>
  // Countdown Timer
  document.addEventListener('DOMContentLoaded', () => {
    const containers = document.querySelectorAll('.countdown-container')

    containers.forEach(container => {
      const raceDate = new Date(container.dataset.raceDate)
      const daysEl = container.querySelector('.countdown-days')
      const hoursEl = container.querySelector('.countdown-hours')
      const minsEl = container.querySelector('.countdown-mins')
      const secsEl = container.querySelector('.countdown-secs')

      const updateCountdown = () => {
        const now = new Date()
        const diff = raceDate.getTime() - now.getTime()

        if (diff <= 0) {
          daysEl.textContent = '0'
          hoursEl.textContent = '0'
          minsEl.textContent = '0'
          secsEl.textContent = '0'
          return
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24))
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))
        const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60))
        const secs = Math.floor((diff % (1000 * 60)) / 1000)

        daysEl.textContent = days.toString().padStart(2, '0')
        hoursEl.textContent = hours.toString().padStart(2, '0')
        minsEl.textContent = mins.toString().padStart(2, '0')
        secsEl.textContent = secs.toString().padStart(2, '0')
      }

      updateCountdown()
      setInterval(updateCountdown, 1000)
    })
  })
  </script>
