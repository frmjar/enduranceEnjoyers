---
import DesktopNav from './navigation/DesktopNav.astro'
import MobileNav from './navigation/MobileNav.astro'

const props = Astro.props

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/#calendario', label: 'Calendario' },
  { href: '/#novedades', label: 'Novedades' },
  { href: '/#twitter', label: 'Twitter' },
  { href: '/#galeria', label: 'Galería' },
  { href: '/#contacto', label: 'Contacto' }
]
---

  <div {...props}>
    <nav
      id='navbar'
      class='fixed top-0 left-0 w-full z-50 transition-all duration-300'
    >
    <!-- Fondo con glassmorphism -->
      <div class='absolute inset-0 bg-racing-dark/90 backdrop-blur-md border-b border-white/5' />

    <!-- Línea accent naranja inferior -->
      <div class='absolute bottom-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-accent-orange to-transparent opacity-60' />

    <!-- Contenido del nav -->
      <div class='relative flex items-center justify-between h-16 md:h-20 px-4 md:px-8 max-w-8xl mx-auto'>
      <!-- Logo -->
        <div id='scroll-logo' class='flex-shrink-0'>
          <a href='/' class='block group'>
            <img
              src='/logotextclear.webp'
              alt='Logo Endurance Enjoyers'
              class='h-10 md:h-12 w-auto transition-transform duration-300 group-hover:scale-105'
            />
          </a>
        </div>

      <!-- Navegación -->
        <DesktopNav links={links} />
        <MobileNav links={links} />
      </div>
    </nav>

  <!-- Espaciador para compensar el header fixed -->
    <div class='h-16 md:h-20' />
  </div>
