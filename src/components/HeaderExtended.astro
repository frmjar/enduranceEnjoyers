---
import { getImage } from 'astro:assets'
import sample from '../assets/banner.png'
import NavbarMovil from './navegacion/NavbarMovil.astro'
import NavbarPc from './navegacion/NavbarPc.astro'

const bannerImages = {
  small: await getImage({ src: sample, width: 640, format: 'webp', quality: 80 }),
  medium: await getImage({ src: sample, width: 1024, format: 'webp', quality: 80 }),
  large: await getImage({ src: sample, width: 1536, format: 'webp', quality: 80 }),
  xlarge: await getImage({ src: sample, width: 2048, format: 'webp', quality: 80 })
}

export interface Props {
  id?: string
}

const props = Astro.props

const links = [
  { href: '#home', label: 'Inicio' },
  { href: '#calendario', label: 'Calendario' },
  { href: '#novedades', label: 'Novedades' },
  { href: '#galeria', label: 'Galería' },
  { href: '#contacto', label: 'Contacto' }
]
---

<div {...props}>
  <link rel='preload' as='image' href={bannerImages.medium.src} media='(min-width: 640px) and (max-width: 1023px)' />
  <link rel='preload' as='image' href={bannerImages.large.src} media='(min-width: 1024px) and (max-width: 1535px)' />
  <link rel='preload' as='image' href={bannerImages.xlarge.src} media='(min-width: 1536px)' />
  <link rel='preload' as='image' href={bannerImages.small.src} media='(max-width: 639px)' />

  <section
    id='navbardir'
    class='relative isolate overflow-hidden w-full bg-racing-black'
    aria-labelledby='hero-title'
    role='banner'
  >
    <picture class='block w-full'>
      <source media='(min-width: 1536px)' srcset={bannerImages.xlarge.src} />
      <source media='(min-width: 1024px)' srcset={bannerImages.large.src} />
      <source media='(min-width: 640px)' srcset={bannerImages.medium.src} />
      <img
        src={bannerImages.small.src}
        alt=''
        aria-hidden='true'
        width={bannerImages.small.width}
        height={bannerImages.small.height}
        fetchpriority='high'
        loading='eager'
        decoding='sync'
        class='block w-full h-auto object-contain object-top'
      />
    </picture>
    <h1 id='hero-title' class='sr-only'>Endurance Enjoyers | Equipo español de simracing y carreras de resistencia en iRacing</h1>
  </section>

  <NavbarPc links={links} />
  <NavbarMovil links={links} />
</div>
